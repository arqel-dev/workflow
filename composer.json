{
    "name": "arqel-dev/workflow",
    "version": "0.8.0",
    "description": "State-machine workflow integration for Arqel — fluent definition + HasWorkflow trait wrapping spatie/laravel-model-states.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "arqel",
        "workflow",
        "state-machine",
        "spatie"
    ],
    "homepage": "https://arqel.dev",
    "support": {
        "issues": "https://github.com/arqel-dev/arqel/issues",
        "source": "https://github.com/arqel-dev/arqel",
        "docs": "https://arqel.dev/docs"
    },
    "require": {
        "php": "^8.3",
        "arqel-dev/core": "@dev",
        "arqel-dev/fields": "@dev",
        "illuminate/support": "^12.0|^13.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.29",
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0"
    },
    "suggest": {
        "spatie/laravel-model-states": "Required to use class-based state objects with transitions (^2.5)."
    },
    "autoload": {
        "psr-4": {
            "Arqel\\Workflow\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Arqel\\Workflow\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Arqel\\Workflow\\WorkflowServiceProvider"
            ]
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "../core",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../fields",
            "options": {
                "symlink": true
            }
        }
    ],
    "scripts": {
        "test": "vendor/bin/pest",
        "test:coverage": "vendor/bin/pest --coverage --min=90",
        "analyse": "phpstan analyse src tests",
        "lint": "pint --test",
        "format": "pint"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
